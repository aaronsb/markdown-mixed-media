{
  "name": "mmm",
  "version": "1.1.0",
  "description": "Mixed Media Markdown - Terminal markdown viewer with sixel graphics support",
  "main": "dist/index-direct.js",
  "bin": {
    "mmm": "./dist/index-direct.js",
    "install-mmm": "./install.js"
  },
  "scripts": {
    "dev": "tsx src/index-direct.tsx",
    "dev:simple": "tsx src/index-simple.tsx",
    "dev:settings": "tsx src/settings-cli.ts",
    "settings": "tsx src/settings-cli.ts",
    "watch": "tsx watch src/index-direct.tsx",
    "start": "node dist/index-direct.js",
    "build": "node scripts/generate-version.js && tsc && chmod +x dist/index-direct.js && chmod +x dist/index-simple.js",
    "build:binary": "npm run build && npm run package",
    "build:simple": "node scripts/build-simple.js",
    "package": "node scripts/build-binary.js",
    "install:local": "npm run build:binary && ./scripts/install.sh",
    "release:create": "./scripts/create-release.sh",
    "aur:update": "./scripts/update-aur.sh"
  },
  "keywords": [
    "markdown",
    "terminal",
    "tui",
    "sixel",
    "mermaid",
    "viewer"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "beautiful-mermaid": "^1.1.3",
    "chalk": "^5.3.0",
    "figlet": "^1.7.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "marked": "~15.0.12",
    "marked-emoji": "^1.4.3",
    "marked-footnote": "^1.2.4",
    "marked-highlight": "^2.2.4",
    "marked-terminal": "^7.3.0",
    "mathjax-full": "^3.2.1",
    "meow": "^13.1.0",
    "node-emoji": "^2.2.0",
    "open": "^10.0.3",
    "sharp": "^0.33.5"
  },
  "optionalDependencies": {
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.19.43",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
